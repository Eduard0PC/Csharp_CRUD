<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="tema5_2.view.AddProfeWindow"
        Width="400" Height="400"
        Title="Agregar Maestro">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Agregar Maestro"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBox Name="txtId" Watermark="ID Profesor"/>
        <TextBox Name="txtNombre" Watermark="Nombre"/>
        <TextBox Name="txtApellido" Watermark="Apellido"/>
        <TextBox Name="txtEmail" Watermark="Email"/>

        <ComboBox Name="cbMaterias"
                  x:CompileBindings="False"
                  DisplayMemberBinding="{Binding Nombre_Materia}"
                  SelectedValueBinding="{Binding ID_Materia}"
                  PlaceholderText="Selecciona una materia"/>

        <Button Content="Agregar"
                HorizontalAlignment="Center"
                Click="Agregar_Click"/>

    </StackPanel>
</Window>