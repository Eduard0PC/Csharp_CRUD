<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="tema5_2.view.AddMateriaWindow"
        Width="400" Height="300"
        Title="Agregar Materia">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Agregar Materia"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBox Name="txtId" Watermark="ID Materia (ej. MAT01)"/>
        <TextBox Name="txtNombre" Watermark="Nombre de la Materia"/>
        <TextBox Name="txtCreditos" Watermark="Créditos (número)"/>

        <Button Content="Agregar"
                HorizontalAlignment="Center"
                Click="Agregar_Click"
                Margin="0,15,0,0"/>

    </StackPanel>
</Window>
